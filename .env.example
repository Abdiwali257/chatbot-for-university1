# Optional. Leave empty if you do not have a Hugging Face token.
HF_TOKEN=
HF_MODEL=Qwen/Qwen2.5-7B-Instruct
HF_PROVIDER=auto
HF_TIMEOUT_SECONDS=60
HF_MAX_TOKENS=450

# NLP embedding model used for document indexing and query search.
# Re-run train_data.py after changing this.
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_BATCH_SIZE=16
CHROMA_ADD_BATCH_SIZE=64
CHUNK_TARGET_SIZE=850
CHUNK_OVERLAP=180
MAX_RETRIEVAL_DISTANCE=0.78

DJANGO_SECRET_KEY=replace-this-before-production
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost,testserver
